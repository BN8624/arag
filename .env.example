# 구글 AI Studio API 키 설정
#
# 1. 이 파일을 같은 폴더에 ".env" 라는 이름으로 복사하세요.
# 2. 아래 줄의 your-api-key-here 자리에 실제 API 키를 붙여넣으세요.
#    (키 발급: https://aistudio.google.com/apikey)
#
# .env 파일은 .gitignore에 의해 깃허브에 올라가지 않습니다.

GOOGLE_API_KEY=your-api-key-here

# (선택) 모델 ID 재정의. check_api.py 실행 결과에 따라 바꿀 수 있습니다.
# GENERATOR_MODEL=gemma-4-26b-a4b-it
# CRITIC_MODEL=gemma-4-31b-it

# (선택) 깃허브 토큰 — 자동 아이디어 출제기가 공개 저장소 메타데이터를 읽는 데 사용.
# 실제 값은 .env에만 넣으세요 (이 예시 파일이 아니라).
# GITHUB_TOKEN=your-github-token-here
